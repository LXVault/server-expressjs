# ---------------------------------------------------------------------------
# Example environment configuration.
# Copy this file to `.env` and adjust the values for your setup.
# Every variable here also has a hard-coded fallback in the application code,
# so the app still boots if a value is missing.
# ---------------------------------------------------------------------------

# --- Backend (server-expressjs) ---
NODE_ENV=development
PORT=4000

# PostgreSQL connection string (pgvector enabled).
# NOTE: this localhost value is for running the backend directly on your host
# (e.g. `npm run dev`). Under Docker Compose it is IGNORED — the backend
# container connects to the `db` service automatically (see docker-compose.yml).
DATABASE_URL=postgresql://mcp_user:mcp_password@localhost:5432/mcp_rag

# Individual DB parts (used by docker-compose / fallback config)
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
POSTGRES_DB=mcp_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Auth
JWT_SECRET=default_jwt_secret_for_development
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Encryption key used to encrypt users' OpenRouter API keys at rest (AES-256-GCM).
# Any string works (it is run through a KDF). MUST be changed in production —
# rotating it makes previously stored keys undecryptable.
ENCRYPTION_KEY=default_encryption_key_change_me_in_production

# OpenRouter (OpenAI-compatible) embeddings base URL. Each user supplies their
# OWN OpenRouter API key via the web app; the server never ships a global key.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# CORS
CORS_ORIGIN=http://localhost:5173

# --- Frontend (client-reactjs) ---
# Base URL the React app uses to reach the backend API. Leave as the relative
# `/api` so nginx (prod) / the Vite dev server proxy the call to the backend;
# only set an absolute URL if the API is hosted on a separate origin.
VITE_API_URL=/api

# Host port the frontend container is published on.
FRONTEND_PORT=5173
