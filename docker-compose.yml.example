# ---------------------------------------------------------------------------
# Example orchestration for the MCP Server + Knowledge Base (RAG) stack.
#
# Copy to `docker-compose.yml` and run `docker compose up --build`.
# Expects the two repositories checked out as siblings:
#
#   <parent>/
#   ├── server-expressjs/   (run docker compose from here)
#   └── client-reactjs/
#
# All values fall back to sensible defaults if the matching variable is unset.
# ---------------------------------------------------------------------------

services:
  db:
    image: pgvector/pgvector:pg16
    container_name: mcp_rag_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-mcp_user}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-mcp_password}
      POSTGRES_DB: ${POSTGRES_DB:-mcp_rag}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
      # Schema is applied automatically on first boot.
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-mcp_user} -d ${POSTGRES_DB:-mcp_rag}"]
      interval: 5s
      timeout: 5s
      retries: 10

  backend:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: mcp_rag_backend
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      NODE_ENV: ${NODE_ENV:-production}
      PORT: ${PORT:-4000}
      # Always target the `db` service on the compose network. We build this
      # from the credential parts (rather than ${DATABASE_URL}) so a localhost
      # DATABASE_URL in .env — meant for running the backend outside Docker —
      # can't leak in and point the container at itself.
      DATABASE_URL: postgresql://${POSTGRES_USER:-mcp_user}:${POSTGRES_PASSWORD:-mcp_password}@db:5432/${POSTGRES_DB:-mcp_rag}
      JWT_SECRET: ${JWT_SECRET:-default_jwt_secret_for_development}
      JWT_EXPIRES_IN: ${JWT_EXPIRES_IN:-7d}
      BCRYPT_SALT_ROUNDS: ${BCRYPT_SALT_ROUNDS:-10}
      CORS_ORIGIN: ${CORS_ORIGIN:-http://localhost:5173}
    ports:
      - "${PORT:-4000}:4000"

  frontend:
    build:
      context: ../client-reactjs
      dockerfile: Dockerfile
      args:
        # Same-origin relative path; nginx proxies /api to the backend service.
        VITE_API_URL: ${VITE_API_URL:-/api}
    container_name: mcp_rag_frontend
    restart: unless-stopped
    depends_on:
      - backend
    ports:
      - "${FRONTEND_PORT:-5173}:80"

volumes:
  pgdata:
